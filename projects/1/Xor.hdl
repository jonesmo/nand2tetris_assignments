/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
        Or(a=a, b=b, out=aOrB);
        Not(in=a, out=notA);
        Not(in=b, out=notB);
        Or(a=notA, b=notB, out=notAOrNotB);
        And(a=aOrB, b=notAOrNotB, out=out);
}